# Convex and Clerk are optional for public previews.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Server-only webhook used for contact enquiries and stored project builder submissions.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=

# Server-only contact detail revealed after an accepted contact enquiry.
DIRECT_CONTACT_MOBILE=

# Optional FastAPI service origin, for example http://localhost:8000.
NEXT_PUBLIC_ASSISTANT_API_URL=

# Backend-only filesystem path used by the optional FastAPI project builder.
PROJECT_BUILDER_SUBMISSIONS_PATH=
