# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Convex deployment
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Must match the Clerk Frontend API / issuer for the active Clerk keys.
# Development keys use https://verb-noun-00.clerk.accounts.dev.
# Production keys may use the McCaigs custom Clerk domain.
CLERK_JWT_ISSUER_DOMAIN=
OWNER_CLERK_USER_ID=

# Optional Convex HTTP actions origin.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Optional application integrations.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
DIRECT_CONTACT_MOBILE=
NEXT_PUBLIC_ASSISTANT_API_URL=
PROJECT_BUILDER_SUBMISSIONS_PATH=

# Studio OS Blog publishing.
# Development defaults to local; production defaults to github.
BLOG_WRITE_MODE=local
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=
